# Copy to .env or .env.local and fill in.
# KAGGLE_USERNAME=
# KAGGLE_KEY=

# Provider selection
# BIOREASONING_LLM_PROVIDER=openai_compatible

# Official / local OpenAI-compatible endpoint (preferred for Track A / B)
# BIOREASONING_OPENAI_API_BASE=http://localhost:8000/v1
# BIOREASONING_OPENAI_API_KEY=token-abc123
# BIOREASONING_OPENAI_MODEL=openai/gpt-oss-120b

# Hosted OpenAI fallback for testing
# OPENAI_API_KEY=

# Hosted Anthropic fallback for testing
# ANTHROPIC_API_KEY=
# BIOREASONING_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Azure OpenAI fallback / enterprise-hosted option
# BIOREASONING_LLM_PROVIDER=azure_openai
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_MODE=key
# AZURE_OPENAI_API_KEY=
# Optional Entra auth instead of key auth:
# AZURE_OPENAI_MODE=entra

# Shared inference controls
# BIOREASONING_REASONING_EFFORT=medium
# BIOREASONING_MAX_COMPLETION_TOKENS=65536

# Canonical local challenge data paths
# BIOREASONING_TRAIN_CSV=data/raw/train.csv
# BIOREASONING_TEST_CSV=data/raw/test.csv
